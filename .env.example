# Core runtime
PERSISTENCE_BACKEND=postgres
POSTGRES_DRIVER_AVAILABLE=true
DATABASE_URL=postgres://postgres:postgres@localhost:5432/openclaw_app
REDIS_URL=redis://localhost:6379

# Runtime safety defaults
MAX_PARALLEL_JOBS=1
DAILY_BUDGET_EUR=10
MAX_RPM_LLM=30
MAX_RPM_TTS=10
MAX_RPM_VIDEO=3
APP_LOG_PATH=logs/app.log

# Auth / entitlement
AUTH_REQUIRED=true
AUTH_METHOD=email
ADMIN_ALLOWLIST=falko@example.com
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feature flags
ENABLE_AUTO_PUBLISH=false

# Alerts
ALERT_TARGET=email
ALERT_EMAIL_SEVERITIES=critical,warn
ALERT_EMAIL_TO=
ALERT_TEST_ALLOWED=true

# Render deployment metadata (no secret)
RENDER_OWNER_NAME=faceless
RENDER_REQUIRED_SERVICES=api,web,postgres,redis
RENDER_REGION=frankfurt
WEBHOOK_BASE_URL=
